# ── Groq ──────────────────────────────────────────
# From console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── SerpAPI ───────────────────────────────────────
# From serpapi.com
SERPAPI_KEY=your_serpapi_key_here


# ── Email (Gmail SMTP) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password   # Use Gmail App Password, not your real password

# ── Your company / service ────────────────────────
YOUR_COMPANY_NAME="Your Company Name"
YOUR_COMPANY_TAGLINE="Tagline of your company"

# ── Google APIs ───────────────────────────────────
# Refer to Readme.md file for setup instructions
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json
SHEETS_SPREADSHEET_ID=your_google_sheet_id_here
DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ── App ───────────────────────────────────────────
DATABASE_URL=sqlite:///./leads.db
REPORTS_DIR=reports
